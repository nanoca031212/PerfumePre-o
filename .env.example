# =============================================================
# TEMPLATE DE VARIÁVEIS DE AMBIENTE
# Copie este arquivo para .env.local e preencha os valores
# NUNCA commite o .env.local no git
# =============================================================

# Ambiente
NODE_ENV=development

# =============================================================
# SITE
# =============================================================
NEXT_PUBLIC_SITE_URL=https://theperfumeuk.shop

# =============================================================
# STRIPE
# =============================================================
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# =============================================================
# META (FACEBOOK)
# Pixel ID: gerenciador de anúncios → Pixels → ID do pixel
# Access Token: gerenciador de anúncios → Pixels → API de Conversões → Gerar token
# Test Event Code: opcional, só para validar eventos no Events Manager
# =============================================================
NEXT_PUBLIC_FACEBOOK_PIXEL_ID_1=1201843863809192
FACEBOOK_ACCESS_TOKEN=EAAxxxxxxxxxxxxx...
FACEBOOK_TEST_EVENT_CODE=

# =============================================================
# TIKTOK
# Pixel ID: TikTok Ads → Assets → Events → Web Events → Pixel ID
# Access Token: TikTok Ads → Assets → Events → Web Events → Generate Access Token
# Se usar 2 pixels (ex: contas diferentes ou split test), preencher ambos
# =============================================================
TIKTOK_PIXEL_ID_1=D72L9I3C77UCBSL4NTIG
TIKTOK_ACCESS_TOKEN_1=seu_token_tiktok_pixel_1
TIKTOK_PIXEL_ID_2=D7M0PSJC77U44OJIKH80
TIKTOK_ACCESS_TOKEN_2=seu_token_tiktok_pixel_2

# =============================================================
# UTMIFY
# Webhook URL: painel UTMify → Integrações → Webhook → copiar URL
# API Key: painel UTMify → Configurações → API → Gerar chave
# Pixel ID (Meta): painel UTMify → Pixels → copiar ID do pixel Meta
# =============================================================
UTMIFY_WEBHOOK_URL=https://api.utmify.com.br/api-credentials/orders
UTMIFY_API_KEY=sua_chave_api_utmify
NEXT_PUBLIC_UTMIFY_PIXEL_ID=68acccb997c810406d624392
